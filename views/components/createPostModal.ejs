<template x-teleport="body">
  <div x-show="openCreatePost" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition ease-in duration-200" class="fixed inset-0 z-60 flex items-center justify-center bg-black/90 backdrop-blur-md p-4" style="display: none;">
    <div @click.away="openCreatePost = false, window.location.href = '/'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-95 translate-y-4" x-transition:enter-end="opacity-100 scale-100 translate-y-0" class="w-full max-w-xl bg-zinc-900 border border-zinc-800 rounded-3xl shadow-2xl overflow-hidden">
      <div class="px-6 py-4 border-b border-zinc-800 flex justify-between items-center bg-zinc-900/50">
        <h3 class="text-lg font-black uppercase italic tracking-tighter">New <span class="text-orange-500">Post</span></h3>
        <button @click="openCreatePost = false, window.location.href = '/'" class="text-zinc-500 hover:text-zinc-100 p-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <form action="/post-message" method="POST" class="p-6">
        <div class="mb-5">
          <label for="title" class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-2">Headline</label>
          <input type="text" id="title" name="title" value="<%= formData?.title || ''%>" placeholder="e.g. Best motorcyle parts to buy" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl py-3 px-4 text-zinc-100 placeholder:text-zinc-600 focus:outline-none focus:ring-2 focus:ring-orange-500/50 focus:border-orange-500 transition-all font-semibold" required />
          <% errors.forEach(error => { %>
          <% if (error.path === 'title') { %>
          <p class="text-red-500"><%= error.msg %></p>
          <% } %>
          <% }) %>
        </div>
        <textarea id="message" name="message" rows="4" placeholder="Tell the crew about your ride, mods, or route..." class="w-full bg-transparent text-zinc-200 placeholder:text-zinc-600 resize-none outline-none text-lg"><%= formData?.message || ''%></textarea>
        <% errors.forEach(error => { %>
        <% if (error.path === 'message') { %>
        <p class="text-red-500"><%= error.msg %></p>
        <% } %>
        <% }) %>
        <div class="mt-4 border-2 border-dashed border-zinc-800 rounded-2xl p-8 flex flex-col items-center justify-center group hover:border-orange-500/30 transition-colors cursor-pointer">
          <div class="p-3 bg-zinc-800 rounded-full text-zinc-500 group-hover:text-orange-500 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </div>
          <p class="mt-2 text-sm text-zinc-500 font-medium">Add Photos of your Build</p>
          <p class="text-[10px] text-zinc-600 uppercase tracking-widest mt-1">High-Res Recommended</p>
        </div>

        <div class="mt-6 flex items-center justify-end pt-4 border-t border-zinc-800">

          <button type="submit" class="bg-orange-600 hover:bg-orange-500 text-white font-black uppercase px-8 py-2.5 rounded-full text-sm tracking-widest transition-all active:scale-95 shadow-lg shadow-orange-900/20">
            Publish
          </button>
        </div>
      </form>
    </div>
  </div>
</template>