 <template x-teleport="body">
   <div x-show="openRegister" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm p-4" style="display: none;">

     <div @click.away="openRegister = false; window.location.href = '/';" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-95" x-transition:enter-end="opacity-100 scale-100" class="w-full max-w-md bg-zinc-950 border border-zinc-800 rounded-2xl shadow-2xl overflow-hidden">
       <div class="h-1.5 w-full bg-orange-600"></div>

       <div class="p-8 overflow-y-auto">
         <div class="flex justify-between items-start mb-8">
           <div>
             <h2 class="text-3xl font-black uppercase italic tracking-tighter text-zinc-100">
               Join the <span class="text-orange-500">Crew</span>
             </h2>
             <p class="text-zinc-500 text-sm mt-1">Create your rider profile to start posting.</p>
           </div>
           <%- include('../partials/modalCloseBtn', { modal: "openRegister" }) %>
         </div>

         <form action="/sign-up" method="post" class="space-y-5">
           <div>
             <label for="username" class="block text-xs font-bold uppercase tracking-widest text-zinc-400 mb-2">Rider Name (Username)</label>
             <input id="username" name="username" type="text" value="<%= formData?.username || '' %>" class="w-full bg-zinc-900 border border-zinc-800 rounded-lg py-3 px-4 text-zinc-200 focus:ring-2 focus:ring-orange-500/50 outline-none" />
             <% errors.forEach(error => { %>
             <% if (error.path === 'username') { %>
             <p class="text-red-500"><%= error.msg %></p>
             <% } %>
             <% }) %>
           </div>
           <div>
             <label for="firstName" class="block text-xs font-bold uppercase tracking-widest text-zinc-400 mb-2">First Name</label>
             <input id="firstName" name="firstName" type="text" value="<%= formData?.firstName || '' %>" class="w-full bg-zinc-900 border border-zinc-800 rounded-lg py-3 px-4 text-zinc-200 focus:ring-2 focus:ring-orange-500/50 outline-none" />
             <% errors.forEach(error => { %>
             <% if (error.path === 'firstName') { %>
             <p class="text-red-500"><%= error.msg %></p>
             <% } %>
             <% }) %>
           </div>
           <div>
             <label for="lastName" class="block text-xs font-bold uppercase tracking-widest text-zinc-400 mb-2">Last Name</label>
             <input id="lastName" name="lastName" type="text" value="<%= formData?.lastName || '' %>" class="w-full bg-zinc-900 border border-zinc-800 rounded-lg py-3 px-4 text-zinc-200 focus:ring-2 focus:ring-orange-500/50 outline-none" />
             <% errors.forEach(error => { %>
             <% if (error.path === 'lastName') { %>
             <p class="text-red-500"><%= error.msg %></p>
             <% } %>
             <% }) %>
           </div>
           <div>
             <label for="password" class="block text-xs font-bold uppercase tracking-widest text-zinc-400 mb-2">Password</label>
             <input id="password" name="password" type="password" value="<%= formData?.password || '' %>" class="w-full bg-zinc-900 border border-zinc-800 rounded-lg py-3 px-4 text-zinc-200 focus:ring-2 focus:ring-orange-500/50 outline-none" />
             <% errors.forEach(error => { %>
             <% if (error.path === 'password') { %>
             <p class="text-red-500"><%= error.msg %></p>
             <% } %>
             <% }) %>
           </div>
           <div>
             <label for="confirmPassword" class="block text-xs font-bold uppercase tracking-widest text-zinc-400 mb-2"> Confirm Password</label>
             <input id="confirmPassword" name="confirmPassword" type="password" class="w-full bg-zinc-900 border border-zinc-800 rounded-lg py-3 px-4 text-zinc-200 focus:ring-2 focus:ring-orange-500/50 outline-none" />
             <% errors.forEach(error => { %>
             <% if (error.path === 'confirmPassword') { %>
             <p class="text-red-500"><%= error.msg %></p>
             <% } %>
             <% }) %>
           </div>
           <button type="submit" class="w-full cursor-pointer bg-orange-600 hover:bg-orange-500 text-white font-black uppercase py-4 rounded-lg tracking-widest transition-all">
             Start Your Engine
           </button>
         </form>
       </div>
     </div>
   </div>
 </template>