<div class="max-w-2xl mx-auto mt-6 px-4">
  <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-4 mb-6 flex items-center gap-4">
    <%- include('./generatedAvatarProfile', {username: locals.user.username}) %>
    <button @click="openCreatePost = true" class="flex-1 bg-zinc-950 border border-zinc-800 text-left px-4 py-2.5 rounded-full text-zinc-500 hover:border-zinc-700 transition-colors text-sm">
      Share your ride, <%= locals.user.username %>...
    </button>
    <button @click="openCreatePost = true" class="text-orange-500 hover:text-orange-400 p-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
    </button>
  </div>
</div>