<article class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden shadow-sm hover:border-zinc-700 transition-colors">

  <div class="p-4 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="h-10 w-10 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center overflow-hidden">
        <img src="https://api.dicebear.com/7.x/bottts/svg?seed=<%= postData?.username || 'Anon'%>" alt="avatar" class="w-full h-full object-cover">
      </div>

      <div>
        <h4 class="text-sm font-bold text-zinc-100 hover:text-orange-500 cursor-pointer transition-colors leading-none">
          <%= postData?.username || 'Anonymouse' %>
        </h4>
        <span class="text-[10px] text-zinc-500 uppercase tracking-widest font-medium">
          Full-Stack Rider
        </span>
      </div>
    </div>

    <time class="text-[11px] text-zinc-500 font-medium">
      <%= postData?.created_at || 'some time ago' %>
    </time>
  </div>

  <div class="px-4 pb-4">
    <h2 class="text-lg md:text-xl font-black italic tracking-tighter text-zinc-100 uppercase mb-2 leading-tight">
      <%= postData.title %>
    </h2>

    <p class="text-sm md:text-base text-zinc-400 leading-relaxed line-clamp-3">
      <%= postData.content %>
    </p>

    <button class="mt-2 text-xs font-bold text-orange-500 hover:text-orange-400 uppercase tracking-wider">
      Read Full Thread
    </button>
  </div>

  <div class="px-4 py-3 border-t border-zinc-800/50 bg-zinc-900/50 flex items-center gap-6">
    <button class="group flex items-center gap-2 text-zinc-500 hover:text-orange-500 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-active:scale-125 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" />
      </svg>
      <span class="text-xs font-bold">12</span>
    </button>

    <button class="group flex items-center gap-2 text-zinc-500 hover:text-sky-500 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
      <span class="text-xs font-bold">5</span>
    </button>
  </div>
</article>