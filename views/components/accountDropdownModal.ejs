<div x-data="{ open: false }" class="relative">

  <button @click="open = !open" @click.away="open = false" class="flex items-center gap-2 p-1 rounded-full border border-transparent hover:border-zinc-800 hover:bg-zinc-900 transition-all focus:outline-none">
    <div class="h-8 w-8 bg-zinc-800 rounded-full flex items-center justify-center border border-zinc-700 text-zinc-400 group-hover:text-orange-500">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
    </div>

    <svg xmlns="http://www.w3.org/2000/svg" :class="open ? 'rotate-180' : ''" class="h-4 w-4 text-zinc-500 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <div x-show="open" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 scale-95 -translate-y-2" x-transition:enter-end="opacity-100 scale-100 translate-y-0" x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 scale-100 translate-y-0" x-transition:leave-end="opacity-0 scale-95 -translate-y-2" class="absolute right-0 mt-3 w-48 bg-zinc-950 border border-zinc-800 rounded-xl shadow-2xl py-2 z-50" style="display: none;">
    <div class="px-4 py-2 border-b border-zinc-900 mb-1">
      <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Rider Profile</p>
    </div>

    <a href="/profile" class="flex items-center gap-3 px-4 py-2 text-sm text-zinc-300 hover:bg-zinc-900 hover:text-orange-500 transition-colors">
      <span>👤</span> Profile
    </a>

    <a href="/settings" class="flex items-center gap-3 px-4 py-2 text-sm text-zinc-300 hover:bg-zinc-900 hover:text-orange-500 transition-colors">
      <span>⚙️</span> Settings
    </a>

    <div class="h-px bg-zinc-900 my-1 mx-2"></div>

    <button @click="window.location.href = '/logout'; localStorage.clear();" class="w-full flex items-center gap-3 px-4 py-2 text-sm text-red-500 hover:bg-red-500/10 transition-colors">
      <span>🏁</span> Logout
    </button>
  </div>
</div>