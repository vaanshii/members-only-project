<!DOCTYPE html>
<html lang="en">
<%- include('./head') %>

<body>
  <div class="min-h-screen bg-zinc-950 flex flex-col items-center justify-center px-6 py-24 sm:py-32 lg:px-8">

    <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-10">
      <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[120%] border-r-40 border-dashed border-zinc-800 rotate-12"></div>
    </div>

    <div class="text-center relative z-10">
      <p class="text-6xl font-black text-orange-600 italic tracking-tighter uppercase">404</p>

      <h1 class="mt-4 text-3xl font-bold tracking-tight text-zinc-100 sm:text-5xl uppercase italic">
        Dead <span class="text-zinc-500">End</span>
      </h1>

      <p class="mt-6 text-base leading-7 text-zinc-400 max-w-md mx-auto">
        Looks like you took a wrong turn at the last fork. This trail hasn't been mapped yet, or the road has been washed out.
      </p>

      <div class="my-10 flex justify-center">
        <div class="h-1 w-20 bg-zinc-800 rounded-full"></div>
        <div class="h-1 w-10 bg-orange-600 rounded-full mx-2"></div>
        <div class="h-1 w-20 bg-zinc-800 rounded-full"></div>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="w-full sm:w-auto bg-zinc-100 text-zinc-950 px-8 py-3 rounded-lg font-black uppercase tracking-widest hover:bg-zinc-300 transition-all active:scale-95">
          Back to Highway
        </a>
      </div>
    </div>

    <p class="absolute bottom-8 text-zinc-600 text-[10px] uppercase tracking-[0.2em]">
      Motoclub V0.1
    </p>
  </div>
</body>

</html>