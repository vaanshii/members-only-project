<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head') %>

<body>
  <div class="min-h-screen bg-zinc-950 text-zinc-100 pb-20">
    <%- include('./partials/navbar') %>

    <div class="bg-zinc-900 border-b border-zinc-800">
      <div class="max-w-2xl mx-auto px-4 py-10">
        <div class="flex flex-col items-center sm:flex-row sm:items-end gap-6">

          <div class="relative group">
            <div class="h-32 w-32 rounded-full bg-zinc-800 border-4 border-zinc-950 flex items-center justify-center overflow-hidden shadow-xl">
              <img src="https://api.dicebear.com/7.x/bottts/svg?seed=<%= userData.username %>" alt="avatar" class="w-full h-full object-cover">
            </div>
            <% if (locals.user.username === userData.username) { %>
            <button onclick="window.location.href = '/profile/<%= userData.username %>/edit'" class="absolute bottom-0 right-0 p-2 bg-orange-600 rounded-full border-2 border-zinc-950 hover:bg-orange-500 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" viewBox="0 0 20 20" fill="currentColor">
                <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
              </svg>
            </button>
            <% } %>

          </div>

          <div class="flex-1 text-center sm:text-left">
            <h1 class="text-3xl font-black italic tracking-tighter uppercase text-zinc-100">
              <%= userData.username %>
            </h1>
            <p class="text-orange-500 font-bold text-xs uppercase tracking-widest mt-1"><%= userData?.motorcycle || '' %></p>
            <p class="text-zinc-400 text-sm mt-3 max-w-md">
              <%= userData?.bio || 'Ride like a wind.' %>
            </p>
          </div>
        </div>

        <div class="flex justify-center sm:justify-start gap-8 mt-8 pt-8 border-t border-zinc-800/50">
          <div class="text-center sm:text-left">
            <span class="block text-xl font-black text-zinc-100 italic"><%= postMessages.length %></span>
            <span class="text-[10px] text-zinc-500 uppercase tracking-widest font-bold">Posts</span>
          </div>
          <div class="text-center sm:text-left">
            <span class="block text-xl font-black text-zinc-100 italic">1.2k</span>
            <span class="text-[10px] text-zinc-500 uppercase tracking-widest font-bold">Upvotes</span>
          </div>

        </div>
      </div>
    </div>

    <div class="max-w-2xl mx-auto mt-8">
      <div class="px-4 mb-6 flex items-center gap-2">
        <div class="h-1 w-8 bg-orange-600 rounded-full"></div>
        <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Recent Activity</h3>
      </div>

      <% if (postMessages.length === 0) { %>
      <div class="max-w-2xl mx-auto px-4 py-20">
        <div class="flex flex-col items-center text-center">

          <div class="relative mb-6">
            <div class="absolute inset-0 bg-orange-600/20 blur-3xl rounded-full"></div>

            <div class="relative bg-zinc-900 border border-zinc-800 p-6 rounded-full shadow-2xl">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-zinc-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 4L9 7" />
              </svg>
            </div>
          </div>

          <h3 class="text-xl font-black italic uppercase tracking-tighter text-zinc-100">
            The Road is <span class="text-orange-500">Empty</span>
          </h3>
          <p class="mt-2 text-sm text-zinc-500 max-w-xs leading-relaxed">
            <%= locals.user.username === userData.username ? "You haven't made any post yet." : "This rider haven't made any post yet"%>
          </p>
          <% if (locals.user.username === userData.username) { %>
          <button onclick="window.location.href = '/'" class="mt-8 flex items-center gap-2 bg-zinc-100 text-zinc-950 px-6 py-2.5 rounded-full font-black uppercase text-xs tracking-widest hover:bg-orange-500 hover:text-white transition-all active:scale-95 shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
            </svg>
            Start a Thread
          </button>
          <% } %>

        </div>
      </div>
      <% } else { %>
      <div class="space-y-6">
        <% postMessages.forEach(postData => { %>
        <%- include('./components/postCard', { postData }) %>
        <% }) %>
      </div>
      <% } %>

    </div>

  </div>
</body>

</html>